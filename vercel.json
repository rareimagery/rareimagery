{
  "installCommand": "cd frontend && npx -y pnpm@9 install --frozen-lockfile",
  "buildCommand": "cd frontend && npx -y pnpm@9 --filter @rareimagery/storefront build",
  "outputDirectory": "frontend/apps/storefront/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/store/rare", "statusCode": 302 }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
